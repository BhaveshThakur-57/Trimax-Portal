# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection (CHANGE THIS — use a strong, unique password)
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/YOUR_DB?retryWrites=true&w=majority

# JWT Secret (MUST be a random 64+ character string — run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Frontend URL (for CORS & password reset links)
FRONTEND_URL=http://localhost:3000

# Email / SMTP (use app-specific passwords, rotate regularly)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# WhatsApp Cloud API (optional)
WA_TOKEN=
WA_PHONE_ID=
